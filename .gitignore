# Go build artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go workspace
go.work.sum

# Vendor (if not vendoring)
vendor/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.*
*.pem

# Docs are local-only (PRD, internal review, and skill artifacts — never commit)
docs/

# Generated drel files (codegen output, regenerated via `drel generate`)
*_drel.go
db/drel_gen.go
# ...but the bundled examples ship their generated code so they compile.
!examples/**/*_drel.go
!examples/**/db/drel_gen.go

# Compiled example binaries (from `go build .` in an example dir)
examples/sqlite-todo/sqlite-todo
examples/outbox/outbox
examples/observability/observability
examples/uuid-keys/uuid-keys

# SQLite test databases
*.db
*.db-journal
*.db-wal
*.db-shm

# Atlas migration lock (local only)
atlas.lock

# Binary output
/bin/
/dist/
/drel
dist/
